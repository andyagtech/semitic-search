# Semitic Search — environment variables
# Copy this file to `.env` and fill in your keys. `.env` is gitignored.

# Anthropic API (primary LLM)
ANTHROPIC_API_KEY=

# OpenRouter (access to many models via one key)
OPENROUTER_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Turso (libsql) — v1 lexical index
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Forvo API (pronunciation audio) — v3
FORVO_API_KEY=
